# Server
PORT=3000
NODE_ENV=development

# Database (connect to Phase 1 PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=fitness_user
DB_PASSWORD=password
DB_DATABASE=fitness_tracker
DB_SSL=false

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# CORS — set to the production frontend URL when deploying
# Leave blank for local development (localhost origins are always allowed)
FRONTEND_URL=
