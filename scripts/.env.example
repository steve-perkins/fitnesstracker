# Copy this file to .env and fill in your values.
# The .env file should NOT be committed to source control.

# --- deploy.py ---
DOCKER_REGISTRY=registry.example.com
VITE_API_BASE_URL=https://api.example.com
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- dump-prod.py ---
PROD_SSH_HOST=your-server.example.com
PROD_SSH_USER=root
PROD_SSH_KEY=~/.ssh/id_rsa
PROD_DB_CONTAINER=db-postgres-fitnesstracker
PROD_DB_NAME=fitnesstracker
PROD_DB_USER=fitnesstracker
